---
import {
  profile,
  skills,
  achievements,
  education,
} from "../../data/portfolio";
---

<aside
  class="w-full lg:w-[20rem] xl:w-[22rem] lg:flex-shrink-0 bg-gray-50 dark:bg-gray-900 p-6 lg:p-8 lg:sticky lg:top-0 lg:h-screen lg:overflow-y-auto sidebar-scrollbar transition-colors duration-300 animate-fade-in"
>
  <div class="space-y-8">
    <div class="flex flex-col items-center text-center gap-3">
      <button
        type="button"
        id="avatar-open"
        class="avatar-trigger relative w-24 h-24 rounded-full overflow-hidden border-4 border-white dark:border-gray-800 shadow-lg cursor-zoom-in transition-transform hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#38BFF7] focus-visible:ring-offset-2 dark:focus-visible:ring-offset-gray-900"
        aria-label={`View photo of ${profile.name}`}
      >
        <img
          alt={profile.name}
          src={profile.avatar}
          class="absolute inset-0 w-full h-full object-cover pointer-events-none"
          style={`object-position: ${profile.avatarPosition}`}
          loading="eager"
        />
      </button>
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">
          {profile.name}
        </h1>
        <p class="text-base text-gray-600 dark:text-gray-400">
          {profile.title}
          {profile.titleNote && (
            <span class="block text-sm mt-0.5 text-gray-500 dark:text-gray-500">
              {profile.titleNote}
            </span>
          )}
        </p>
      </div>
    </div>

    <div class="flex flex-col gap-4 -mt-2">
      <div class="flex justify-center gap-3 px-3 py-2">
        {
          profile.phone && (
            <a href={profile.phoneTel} class="icon-badge" aria-label="Phone">
              <svg
                class="w-5 h-5 text-gray-700 dark:text-gray-200"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                />
              </svg>
            </a>
          )
        }
        {
          profile.linkedin && (
            <a
              href={profile.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="icon-badge"
              aria-label="LinkedIn"
            >
              <svg class="w-5 h-5 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                />
              </svg>
            </a>
          )
        }
        <a
          href={profile.github}
          target="_blank"
          rel="noopener noreferrer"
          class="icon-badge"
          aria-label="GitHub"
        >
          <svg class="w-5 h-5 text-gray-900 dark:text-white" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
            />
          </svg>
        </a>
        <a
          href={profile.gmailCompose}
          target="_blank"
          rel="noopener noreferrer"
          class="icon-badge"
          aria-label={`Email ${profile.email}`}
          title={profile.email}
        >
          <svg
            class="w-5 h-5 text-gray-700 dark:text-gray-200"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            />
          </svg>
        </a>
      </div>
      <div class="flex gap-2 text-sm justify-center flex-wrap">
        <a
          class="sidebar-action-btn flex-none w-28 flex items-center gap-2 px-2.5 py-1.5 bg-gray-200 dark:bg-gray-800 rounded-full text-gray-800 dark:text-gray-200 hover:bg-gray-300 dark:hover:bg-gray-700 active:scale-95 justify-center"
          href={profile.cvViewUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
            />
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
            />
          </svg>
          View CV
        </a>
        <a
          href={profile.cvDownloadUrl}
          download={profile.cvDownloadName}
          class="sidebar-action-btn flex-none w-28 flex items-center gap-2 px-2.5 py-1.5 bg-gray-200 dark:bg-gray-800 rounded-full text-gray-800 dark:text-gray-200 hover:bg-gray-300 dark:hover:bg-gray-700 active:scale-95 justify-center"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
            />
          </svg>
          Download
        </a>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Contact</h2>
      <div class="space-y-2 text-sm">
        {
          profile.phone && (
            <p class="text-gray-700 dark:text-gray-300 font-semibold m-0">
              <span class="font-medium">Phone:</span> {profile.phone}
            </p>
          )
        }
        <p class="text-gray-700 dark:text-gray-300 font-semibold m-0">
          <span class="font-medium">Email:</span>
          <a
            href={profile.gmailCompose}
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 dark:text-blue-400 hover:underline ml-1 break-all"
          >
            {profile.email}
          </a>
        </p>
        <p class="text-gray-700 dark:text-gray-300 font-semibold m-0">
          <span class="font-medium">Location:</span> {profile.location}
        </p>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3">About Me</h2>
      <p class="text-gray-700 dark:text-gray-300 leading-relaxed text-sm m-0">
        {profile.about}
      </p>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Skills</h2>
      <div class="flex flex-wrap gap-2">
        {
          skills.map((skill) => (
            <span class="px-3 py-1 bg-gray-200 dark:bg-gray-800 rounded-lg text-sm text-gray-800 dark:text-gray-200 hover:scale-105 cursor-default font-semibold transition-transform">
              {skill}
            </span>
          ))
        }
      </div>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Achievements</h2>
      <ul class="space-y-2.5">
        {
          achievements.map((item) => (
            <li class="flex items-center gap-2 text-gray-700 dark:text-gray-300">
              <svg
                class="w-5 h-5 text-gray-600 dark:text-gray-400 flex-shrink-0"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                {item.icon === "work" && (
                  <path d="M20 6h-2.18c.11-.31.18-.65.18-1a2.996 2.996 0 00-5.5-1.65l-.5.67-.5-.68C10.96 2.54 10 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.62 12 11 8.76l1-1.36 1 1.36L15.38 12 17 10.83 14.92 8H20v6z" />
                )}
                {item.icon === "apps" && (
                  <path d="M4 8h4V4H4v4zm6 12h4v-4h-4v4zm-6 0h4v-4H4v4zm0-6h4v-4H4v4zm6 0h4v-4h-4v4zm6-10v4h4V4h-4zm-6 4h4V4h-4v4zm6 6h4v-4h-4v4zm0 6h4v-4h-4v4z" />
                )}
                {item.icon === "code" && (
                  <path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z" />
                )}
                {item.icon === "deploy" && (
                  <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM17 13l-5 5-1.41-1.41L13.17 13H7v-2h6.17l-2.58-2.59L12 7l5 5z" />
                )}
              </svg>
              <span class="font-semibold text-sm">{item.text}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Education</h2>
      <div class="space-y-1">
        <p class="text-gray-700 dark:text-gray-300 font-medium text-sm m-0">
          {education.degree}
        </p>
        <p class="text-gray-600 dark:text-gray-400 text-sm m-0">{education.school}</p>
        {education.period && (
          <p class="text-gray-500 dark:text-gray-500 text-sm m-0 mt-1">{education.period}</p>
        )}
      </div>
    </div>

    <button
      type="button"
      id="theme-toggle"
      class="w-full py-2 px-4 rounded-lg bg-gray-200 dark:bg-gray-800 text-gray-800 dark:text-gray-200 text-sm font-semibold hover:bg-gray-300 dark:hover:bg-gray-700 transition-colors"
    >
      Toggle theme
    </button>
  </div>
</aside>

<div
  id="avatar-modal"
  class="avatar-modal fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-black/80 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Profile photo"
>
  <button
    type="button"
    id="avatar-modal-backdrop"
    class="absolute inset-0 cursor-zoom-out"
    aria-label="Close photo"
  />
  <img
    src={profile.avatar}
    alt={profile.name}
    class="avatar-modal-image relative z-10 max-w-full max-h-[90vh] w-auto h-auto rounded-2xl shadow-2xl object-contain"
  />
  <button
    type="button"
    id="avatar-modal-close"
    class="absolute top-4 right-4 z-20 w-10 h-10 rounded-full bg-white/90 dark:bg-gray-800 text-gray-800 dark:text-white text-xl font-bold flex items-center justify-center hover:bg-white shadow-lg"
    aria-label="Close"
  >
    ×
  </button>
</div>

<script>
  const root = document.documentElement;
  const stored = localStorage.getItem("theme");
  if (stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
    root.classList.add("dark");
  }

  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    root.classList.toggle("dark");
    localStorage.setItem(root.classList.contains("dark") ? "dark" : "light");
  });

  function setupAvatarModal() {
    const modal = document.getElementById("avatar-modal");
    const openBtn = document.getElementById("avatar-open");
    const closeBtn = document.getElementById("avatar-modal-close");
    const backdrop = document.getElementById("avatar-modal-backdrop");
    if (!modal || !openBtn) return;

    const open = () => {
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      document.body.style.overflow = "hidden";
    };

    const close = () => {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      document.body.style.overflow = "";
    };

    openBtn.addEventListener("click", open);
    closeBtn?.addEventListener("click", close);
    backdrop?.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal.classList.contains("hidden")) close();
    });
  }

  setupAvatarModal();
  document.addEventListener("astro:page-load", setupAvatarModal);
</script>
