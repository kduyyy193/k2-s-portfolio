---
import MainHead from "./MainHead.astro";
import { profile } from "../data/portfolio";
import "../styles/portfolio.css";

const { title, seoDesc, seoTitle } = Astro.props;
const pageTitle = title ?? `${profile.name} Portfolio`;
const pageSeoTitle = seoTitle ?? `${profile.name}, ${profile.title}`;
const pageSeoDesc =
  seoDesc ?? `${profile.title} portfolio showcasing projects and experience.`;
---

<html lang="en">
  <MainHead title={pageTitle} seoTitle={pageSeoTitle} seoDesc={pageSeoDesc} />
  <body class="bg-[#F3F4F6] dark:bg-gray-950 text-gray-900 dark:text-gray-100 transition-colors duration-300 min-h-screen">
    <slot />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        if (
          stored === "dark" ||
          (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)
        ) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <style>
      body {
        font-family: "Carlito", system-ui, sans-serif;
      }
    </style>
  </body>
</html>
