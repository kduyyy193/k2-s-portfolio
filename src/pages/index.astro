---
import PortfolioLayout from "../layouts/PortfolioLayout.astro";
import Sidebar from "../components/portfolio/Sidebar.astro";
import ExperienceTimeline from "../components/portfolio/ExperienceTimeline.astro";
import SideProjectTimeline from "../components/portfolio/SideProjectTimeline.astro";
import { profile } from "../data/portfolio";
---

<PortfolioLayout>
  <div class="flex flex-col lg:flex-row min-h-screen">
    <Sidebar />
    <main
      class="flex-1 min-w-0 w-full p-6 lg:py-10 lg:px-8 xl:px-10 transition-colors duration-300 animate-fade-in bg-[#F3F4F6] dark:bg-gray-950 min-h-screen"
    >
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-6 lg:hidden text-center">
        {profile.name} · {profile.title}
      </p>
      <ExperienceTimeline />
      <SideProjectTimeline />
      <footer class="text-center py-8 text-sm text-gray-500 dark:text-gray-400">
        © {new Date().getFullYear()} {profile.name}. All rights reserved.
      </footer>
    </main>
  </div>
</PortfolioLayout>

<script>
  function setupTimelineToggles() {
    document.querySelectorAll(".timeline-toggle").forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.getAttribute("data-toggle-for");
        if (!id) return;
        const content = document.querySelector(
          `[data-content-for="${id}"]`
        ) as HTMLElement | null;
        const icon = button.querySelector(".toggle-icon");
        if (!content) return;
        const collapsed = content.classList.toggle("collapsed");
        icon?.classList.toggle("collapsed", collapsed);
      });
    });
  }

  setupTimelineToggles();
  document.addEventListener("astro:page-load", setupTimelineToggles);
</script>
